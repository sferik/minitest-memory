module Minitest
  module Memory
    VERSION: String

    class AllocationCounter
      class Allocation < ::Struct[Integer]
        attr_accessor count: Integer
        attr_accessor size: Integer
        attr_accessor sources: Hash[String, Integer]

        def self.new: (Integer count, Integer size, Hash[String, Integer] sources) -> instance
      end

      class Result < ::Struct[untyped]
        attr_accessor allocated: Hash[untyped, Allocation]
        attr_accessor ignored: Hash[untyped, Allocation]
        attr_accessor total: Allocation

        def self.new: (Hash[untyped, Allocation] allocated, Hash[untyped, Allocation] ignored, Allocation total) -> instance
      end

      SLOT_SIZE: Integer
      EMPTY: Allocation

      # Returns false on TruffleRuby, true otherwise.
      def self.supported?: () -> bool

      # Counts allocations by class within a block.
      def self.count: (?Array[Module] klasses) { (untyped) -> untyped } -> Result

      # Counts retained allocations by class within a block.
      def self.count_retained: (?Array[Module] klasses) { (untyped) -> untyped } -> Result

      # Returns a Result of allocations from a given generation.
      def self.count_allocations: (Integer generation, ?Array[Module] klasses) -> Result

      private

      # Traces object allocations within a block.
      def self.trace: (Array[Module] klasses, ?retain: bool) { (untyped) -> untyped } -> Result

      # Tallies one object's count and byte size into total and bucket.
      def self.tally: (untyped obj, Allocation total, Allocation bucket) -> void

      # Records the source location of obj into total and bucket source hashes.
      def self.record_source: (untyped obj, Allocation total, Allocation bucket) -> void

      # Finds or creates the Allocation entry for obj.
      def self.bucket_for: (untyped obj, Array[Module] klasses, Hash[untyped, Allocation] allocated, Hash[untyped, Allocation] ignored) -> Allocation
    end

    include Minitest::Assertions

    type allocation_count_limit = Integer | Range[Integer]
    type allocation_limit = allocation_count_limit | Hash[Symbol, allocation_count_limit]

    # Includes Expectations into Minitest::Expectation when minitest/spec is loaded.
    def self.included: (Module base) -> void

    # Fails if any class in limits exceeds its allocation limit.
    def assert_allocations: (Hash[untyped, allocation_limit] limits) { (untyped) -> untyped } -> void

    # Fails if any class in limits exceeds its retention limit.
    def assert_retentions: (Hash[untyped, allocation_limit] limits) { (untyped) -> untyped } -> void

    # Fails if any of the given classes are allocated within a block.
    def refute_allocations: (*Class classes) { (untyped) -> untyped } -> void

    # Fails if any of the given classes are retained within a block.
    def refute_retentions: (*Class classes) { (untyped) -> untyped } -> void

    # Minitest::Spec expectations for memory allocation assertions.
    module Expectations
      # The test context from Minitest::Expectation.
      def ctx: () -> untyped

      # The target value or block from Minitest::Expectation.
      def target: () -> untyped

      # See Minitest::Memory#assert_allocations.
      def must_limit_allocations: (Hash[untyped, allocation_limit] limits) -> void

      # See Minitest::Memory#assert_retentions.
      def must_limit_retentions: (Hash[untyped, allocation_limit] limits) -> void

      # See Minitest::Memory#refute_allocations.
      def wont_allocate: (*Class classes) -> void

      # See Minitest::Memory#refute_retentions.
      def wont_retain: (*Class classes) -> void
    end

    private

    # Checks all limits entries against result.
    def check_limits: (Hash[untyped, allocation_limit] limits, AllocationCounter::Result result, ?metric: String, ?size_metric: String) -> void

    # Dispatches a single limit entry for the given klass against the result.
    def check_limit_entry: (untyped klass, allocation_limit limit, AllocationCounter::Result result, metric: String, size_metric: String) -> void

    # Checks a total :count or :size limit against the aggregate total allocation.
    def check_total_limit: (:count | :size klass, allocation_count_limit limit, AllocationCounter::Allocation total, size_metric: String) -> void

    # Checks per-class limit against allocation for the given klass.
    def check_class_limit: (untyped klass, AllocationCounter::Allocation allocation, allocation_limit limit, metric: String, size_metric: String) -> void

    # Asserts that actual falls within limit for the given klass and metric.
    def check_limit: (untyped klass, allocation_count_limit limit, Integer actual, ?metric: String, sources: Hash[String, Integer]) -> void

    # Asserts zero allocations for each class in classes.
    def check_zero: (AllocationCounter::Result result, Array[Class] classes, ?metric: String) -> void

    # Formats allocation sources as a newline-separated list of source locations.
    def format_sources: (Hash[String, Integer] sources) -> String
  end
end
